</div>

<!-- CATÁLOGO -->
<section class="catalog" id="catalogo">
  <div class="section-header">
    <h2 class="section-title">Más vendidos</h2>
    <a href="#" class="section-link">Ver todos →</a>
  </div>
  <div class="books-grid">

    <div class="catalog-book">
