<script>
  // Categorías activas
  document.querySelectorAll('.cat-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
    });
  });

  // Botones de agregar al carrito
  let cartCount = 0;
  document.querySelectorAll('.add-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      cartCount++;
      const navCta = document.querySelector('.nav-cta');
      if (navCta) navCta.textContent = `Mi carrito (${cartCount})`;
      btn.textContent = '✓';
      btn.style.background = 'var(--musgo)';
      setTimeout(() => { btn.textContent = '+'; btn.style.background = ''; }, 1500);
    });
  });

  // Botón "Agregar" del destacado
  const featuredBtn = document.querySelector('.hero-visual .btn-primary');
  if (featuredBtn) {
    featuredBtn.addEventListener('click', () => {
      cartCount++;
      const navCta = document.querySelector('.nav-cta');
      if (navCta) navCta.textContent = `Mi carrito (${cartCount})`;
      featuredBtn.textContent = '✓ Agregado';
      setTimeout(() => { featuredBtn.textContent = 'Agregar al carrito'; }, 1500);
    });
  }

  // Newsletter
  const newsletterBtn = document.querySelector('.newsletter-form button');
  const newsletterInput = document.querySelector('.newsletter-form input');
  if (newsletterBtn) {
    newsletterBtn.addEventListener('click', () => {
      if (newsletterInput && newsletterInput.value.includes('@')) {
        newsletterBtn.textContent = '¡Listo!';
        newsletterBtn.style.background = 'var(--musgo)';
        newsletterInput.value = '';
        newsletterInput.placeholder = 'Suscripción confirmada';
      } else {
        newsletterInput.style.border = '1px solid var(--terracota)';
        setTimeout(() => { newsletterInput.style.border = ''; }, 1500);
      }
    });
  }
</script>

